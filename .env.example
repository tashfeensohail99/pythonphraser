# ---- Auth (required) ----
# Shared secret with the NestJS backend. The backend signs each request body
# with HMAC-SHA256 using this value; the parser refuses to run without it.
PYTHON_HMAC_SECRET=change-me-shared-with-backend

# ---- OpenAI (optional but recommended) ----
# Without a key the parser still does OCR + photo checks but returns
# NEEDS_REVIEW for text classification/extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# ---- Google Vision OCR (optional) ----
# Paste the full service-account JSON (single line) — handy on Railway where
# you can't mount a credentials file. Alternatively set
# GOOGLE_APPLICATION_CREDENTIALS to a file path and leave this blank.
GOOGLE_VISION_CREDENTIALS_JSON=

# ---- Redis cache (optional) ----
# When unset, an in-process LRU is used (fine for a single instance).
REDIS_URL=

# ---- Cost controls (optional; sane defaults) ----
MAX_VISION_PAGES=3
VISION_COST_CENTS_PER_PAGE=0.15
NATIVE_TEXT_MIN_CHARS=120
HIGH_CONFIDENCE=0.90
MAX_FILE_MB=25
